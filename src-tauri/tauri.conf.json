{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parsa Dental & Implants Clinic",
  "version": "0.1.0",
  "identifier": "com.parsa.technology.dentalclinic",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Parsa Dental & Implants Clinic",
        "width": 1000,
        "height": 600,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Parsa Technology",
    "targets": "nsis",
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png"],
    "windows": {
      "wix": {
        "language": "en-US",
        "template": "default"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "startMenuFolder": "Parsa Technology"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://releases.khwaja-clinic.com/update/{{target}}-{{arch}}/{{current_version}}"
      ]
    }
  }
}
